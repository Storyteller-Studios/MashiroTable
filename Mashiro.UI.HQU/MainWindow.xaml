<Window
    x:Class="Mashiro.UI.HQU.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Mashiro.UI.HQU"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:webview2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Mashiro.UI.HQU"
    Width="1280"
    Height="720"
    ui:WindowHelper.UseModernWindowStyle="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <DatePicker x:Name="SemesterStrtDatePicker" />
            <CheckBox
                x:Name="VPNCheckBox"
                Margin="10,0,0,0"
                Checked="VPNCheckBox_Checked"
                Content="使用VPN连接教务系统"
                Unchecked="VPNCheckBox_Unchecked" />
            <Button
                x:Name="Start"
                Margin="10,0,0,0"
                Click="Start_Click"
                Content="开始导出" />
            <Button
                x:Name="Redirect"
                Margin="10,0,0,0"
                Click="Redirect_Click"
                Content="重定向至教务网页" />
        </StackPanel>
        <webview2:WebView2
            x:Name="Browser"
            Grid.Row="1"
            CoreWebView2InitializationCompleted="Browser_CoreWebView2InitializationCompleted"
            Source="https://jwapp.hqu.edu.cn/"
            Unloaded="Browser_Unloaded" />
    </Grid>
</Window>
