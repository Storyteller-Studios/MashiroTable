<Window
    x:Class="Mashiro.UI.HQU.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:Mashiro.UI.HQU"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ui="http://schemas.modernwpf.com/2019"
    xmlns:webview2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
    Title="Mashiro.UI.HQU"
    Width="1280"
    Height="720"
    ui:WindowHelper.UseModernWindowStyle="True"
    mc:Ignorable="d">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <DatePicker x:Name="SemesterStrtDatePicker" />
            <Button
                x:Name="Start"
                Click="Start_Click"
                Content="开始导出" />
        </StackPanel>
        <webview2:WebView2
            x:Name="Browser"
            Grid.Row="1"
            CoreWebView2InitializationCompleted="Browser_CoreWebView2InitializationCompleted"
            Source="https://jwapp.hqu.edu.cn/jwapp/sys/wdkb/*default/index.do?EMAP_LANG=zh#/xskcb"
            Unloaded="Browser_Unloaded" />
    </Grid>
</Window>
